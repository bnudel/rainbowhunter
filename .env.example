# Neon / Vercel Postgres connection string. If unset, the app falls back to an
# in-memory cache (fine for local dev, but no caching across serverless calls).
DATABASE_URL=

# Optional: grid spacing in km for the search disc (smaller = finer + more API calls).
# Default 14. ~14km over a 100mi radius is a few hundred cells.
GRID_SPACING_KM=14
